{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=QuantityMeasurementDb;User Id=sa;Password=Insane@1234;TrustServerCertificate=True;MultipleActiveResultSets=True",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "RepositorySettings": {
    "UseDatabaseRepository": true,
    "RepositoryType": "Database"
  },
  "CacheSettings": {
    "UseRedisCache": true,
    "CacheDurationSeconds": 300,
    "EnableResponseCaching": true
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyForJWTTokenGeneration1234567890!@#$%",
    "Issuer": "QuantityMeasurementApi",
    "Audience": "QuantityMeasurementClients",
    "ExpirationMinutes": 60
  },
  "GoogleAuth": {
  "ClientId": "ENV_CLIENT_ID",
  "ClientSecret": "ENV_CLIENT_SECRET"
},
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/quantity-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "RedisCache": {
    "InstanceName": "QuantityApi_",
    "DefaultExpirationMinutes": 10
  },
  "AllowedHosts": "*"
}
