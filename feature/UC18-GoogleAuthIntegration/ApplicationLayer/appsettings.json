{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=QuantityMeasurementDb;Username=postgres;Password=1234",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "RepositorySettings": {
    "UseDatabaseRepository": true,
    "RepositoryType": "Database"
  },
  "CacheSettings": {
    "UseRedisCache": true,
    "CacheDurationSeconds": 300,
    "EnableResponseCaching": true
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "QuantityMeasurementApi",
    "Audience": "QuantityMeasurementClients",
    "ExpirationMinutes": 60
  },
  "GoogleAuth": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/quantity-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "RedisCache": {
    "InstanceName": "QuantityApi_",
    "DefaultExpirationMinutes": 10
  },
  "AllowedHosts": "*"
}
